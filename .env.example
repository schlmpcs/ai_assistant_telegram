# ── This assistant bot (create a NEW bot via @BotFather) ──
BOT_TOKEN=
OWNER_IDS=[123456789]          # your own Telegram user id(s)
OWNER_NAME=me                  # your name/handle — used in the prompt ("texting as <name>")

# ── LLM (any OpenAI-compatible API — pick ONE provider below) ──
# OpenAI (reliable, paid; cheap with gpt-4o-mini):
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=                              # sk-... from platform.openai.com
LLM_MODELS=["gpt-4o-mini"]
#
# OpenRouter (free models, rate-limited):
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   LLM_API_KEY=sk-or-...                 # https://openrouter.ai/keys
#   LLM_MODELS=["meta-llama/llama-3.3-70b-instruct:free","deepseek/deepseek-r1:free"]
#
# Local Ollama on a GPU box (free, private; bot must reach the GPU host):
#   LLM_BASE_URL=http://host.docker.internal:11434/v1
#   LLM_API_KEY=ollama                    # any non-empty placeholder
#   LLM_MODELS=["qwen2.5:7b-instruct"]
#
LLM_TIMEOUT=60
LLM_MAX_TOKENS=280

# ── Style learning ──
STYLE_NUM_EXAMPLES=25         # how many learned example pairs to inject into the prompt

# ── This bot's own state store ──
LOCAL_DB_PATH=./data/assistant.db

# ── Behaviour ──
AUTO_REPLY=true               # auto-send replies (sensitive topics always draft for approval)
REPLY_RATE_PER_MIN=15         # abuse guard: max AI replies per contact / minute
REPLY_RATE_PER_HOUR=150       # abuse guard: max AI replies per contact / hour
REPLY_DEBOUNCE_SECONDS=2.5    # wait this long for follow-up messages, then answer the whole burst at once
MANAGER_TAKEOVER_HOURS=24     # after you reply by hand, stay silent in that chat this long
